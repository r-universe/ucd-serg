[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "diffviewer"]
	path = diffviewer
	url = https://github.com/d-morrison/diffviewer
	branch = copilot/use-diffobj-diffstr-to-compare-rds-files
	registered = false
[submodule "serocalculator"]
	path = serocalculator
	url = https://github.com/ucd-serg/serocalculator
[submodule "snapr"]
	path = snapr
	url = https://github.com/d-morrison/snapr
	registered = false
